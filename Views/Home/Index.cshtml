@model AttendanceList.Models.PaginatedList<AttendanceList.Models.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance List";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h3 class="mb-0">Attendance List</h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Employee Id</th>
                        <th>Employee Name</th>
                        <th>Department</th>
                        <th>Attendance Date</th>
                        <th>Shift</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.EmployeeId</td>
                            <td>@item.EmployeeName</td>
                            <td>@item.Department</td>
                            <td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.Shift</td>
                            <td>
                                @{
                                    string badgeClass = item.Status switch
                                    {
                                        "Present"  => "bg-success",
                                        "Absent"   => "bg-danger",
                                        "Late"     => "bg-warning text-dark",
                                        "Half Day" => "bg-info text-dark",
                                        "On Leave" => "bg-secondary",
                                        _          => "bg-light text-dark"
                                    };
                                }
                                <span class="badge rounded-pill @badgeClass">@item.Status</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Detail</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination controls *@
        <nav class="mt-3" aria-label="Attendance pagination">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">

                @* Page size selector *@
                <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
                    <label for="pageSize" class="form-label mb-0 text-nowrap">Rows per page:</label>
                    <select id="pageSize" name="pageSize" class="form-select form-select-sm" style="width:80px" onchange="this.form.submit()">
                        @foreach (var size in new[] { 10, 20, 50, 100 })
                        {
                            if (size == Model.PageSize)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                        @{
                            bool allSelected = Model.PageSize <= 0 || Model.PageSize >= Model.TotalCount;
                        }
                        @if (allSelected)
                        {
                            <option value="0" selected>All</option>
                        }
                        else
                        {
                            <option value="0">All</option>
                        }
                    </select>
                    <input type="hidden" name="page" value="1" />
                </form>

                @* Page navigation *@
                <ul class="pagination pagination-sm mb-0">
                    @* First *@
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-pageSize="@Model.PageSize" aria-label="First">
                            &laquo;&laquo;
                        </a>
                    </li>
                    @* Previous *@
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize" aria-label="Previous">
                            &laquo;
                        </a>
                    </li>

                    @* Window of page numbers *@
                    @{
                        int windowSize = 5;
                        int halfWindow = windowSize / 2;
                        int startPage = Math.Max(1, Model.PageNumber - halfWindow);
                        int endPage   = Math.Min(Model.TotalPages, startPage + windowSize - 1);
                        startPage     = Math.Max(1, endPage - windowSize + 1);
                    }
                    @for (int p = startPage; p <= endPage; p++)
                    {
                        <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-pageSize="@Model.PageSize">@p</a>
                        </li>
                    }

                    @* Next *@
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize" aria-label="Next">
                            &raquo;
                        </a>
                    </li>
                    @* Last *@
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" aria-label="Last">
                            &raquo;&raquo;
                        </a>
                    </li>
                </ul>

                <small class="text-muted">
                    Showing @((Model.PageNumber - 1) * Model.PageSize + 1)–@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))
                    of @Model.TotalCount
                </small>
            </div>
        </nav>
    </div>
</div>
