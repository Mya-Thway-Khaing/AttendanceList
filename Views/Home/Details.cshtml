@model AttendanceList.Models.AttendanceRecord

@{
    ViewData["Title"] = "Attendance Details";
}

<div class="card shadow-sm">
    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0">Attendance Details</h3>
        <a asp-action="Index" class="btn btn-light btn-sm">Cancel</a>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.Id</dd>

            <dt class="col-sm-4">Employee Id</dt>
            <dd class="col-sm-8">@Model.EmployeeId</dd>

            <dt class="col-sm-4">Employee Name</dt>
            <dd class="col-sm-8">@Model.EmployeeName</dd>

            <dt class="col-sm-4">Attendance Date</dt>
            <dd class="col-sm-8">@Model.AttendanceDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>

            <dt class="col-sm-4">Department</dt>
            <dd class="col-sm-8">@Model.Department</dd>

            <dt class="col-sm-4">Shift</dt>
            <dd class="col-sm-8">@Model.Shift</dd>

            <dt class="col-sm-4">Notes</dt>
            <dd class="col-sm-8">@Model.Notes</dd>
        </dl>
    </div>
</div>
